// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// For the demo/pitch, we use SQLite to ensure it runs out-of-the-box without requiring 
// the investor/judge to install a local PostgreSQL daemon. The relational architecture remains 1:1.
datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  country      String
  kycStatus    String   @default("PENDING") // PENDING, VERIFIED, REJECTED
  kycHash      String? // SHA256 of KYC reference
  fiatBalance  Float    @default(0.0)
  createdAt    DateTime @default(now())

  // Relations
  wallets      Wallet[]
  transactions Transaction[]
}

model Wallet {
  id              String   @id @default(uuid())
  userId          String
  solanaPublicKey String   @unique
  encryptedSecret String // Encrypted private key for platform custodial ops
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Transaction {
  id                 String   @id @default(uuid())
  userId             String
  direction          String // US_TO_INDIA or INDIA_TO_US
  fromCountry        String
  toCountry          String
  sendCurrency       String
  receiveCurrency    String
  sendAmount         Float
  exchangeRate       Float
  fxSpread           Float
  serviceFee         Float
  taxAmount          Float
  estimatedPayout    Float
  blockchainTxHash   String?
  blockchainMemoHash String?
  status             String   @default("draft") // draft -> initiated -> funded -> converted_to_usdc -> broadcasted_to_solana -> confirmed_on_chain -> off_ramp_processing -> completed
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user             User              @relation(fields: [userId], references: [id])
  complianceRecord ComplianceRecord?
  ledgerEvents     LedgerEvent[]
}

model ComplianceRecord {
  id                   String   @id @default(uuid())
  transactionId        String   @unique
  purposeCode          String?
  lrsDeclaration       Boolean  @default(false)
  sanctionsCheckStatus String   @default("PENDING") // PENDING, CLEARED, FLAGGED
  riskScore            Float    @default(0.0)
  createdAt            DateTime @default(now())

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
}

model LedgerEvent {
  id            String   @id @default(uuid())
  transactionId String
  eventType     String
  metadataJson  String // JSON payload of event specifics
  timestamp     DateTime @default(now())

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
}
